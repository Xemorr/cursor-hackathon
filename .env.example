# =============================================================================
# PesterPay — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# All integrations degrade gracefully to demo/template mode when vars are missing.
# =============================================================================

# =============================================================================
# Ollama — Local LLM for SMS/call copy generation (optional)
#
# Ollama generates communication copy only.
# It must never decide payment status, state transitions, or debt closure.
# If unavailable, the app falls back to messageTemplates automatically.
#
# Setup: https://ollama.com — run `ollama pull llama3.2:3b` to download the model.
# =============================================================================
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Twilio — SMS and voice call delivery (optional)
#
# DEMO SAFETY CONTRACT:
#   - Only DEMO_SAM_PHONE_NUMBER should receive real messages or calls in demo mode.
#   - Maximum 3 messages per debtor; maximum 1 call per debtor.
#   - Never send abusive, threatening, or coercive content.
#   - Never represent PesterPay as a bank, regulator, court, solicitor, or debt collector.
#   - If any credential is missing, the app records a fallback event instead of calling Twilio.
#
# Setup: https://console.twilio.com — get SID, token, and a phone number.
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEMO_SAM_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DEMO_SAM_WHATSAPP_NUMBER=whatsapp:+447449201211
TWILIO_WHATSAPP_STATUS_CALLBACK=

# =============================================================================
# Starling — Settle Up link and read-only transaction polling (optional)
#
# DEMO SAFETY CONTRACT:
#   - Read-only access only — polling transactions to reconcile payments.
#   - Never write payment data or move money through this integration.
#   - STARLING_SETTLE_UP_LINK is the pre-generated Settle Up URL for the demo account.
#   - If credentials are missing, the app falls back to the demo payment page.
#
# Setup: https://developer.starlingbank.com — create a personal access token with
# read-only transaction scope. Get account/category UIDs from the account API.
# =============================================================================
STARLING_ACCESS_TOKEN=
STARLING_ACCOUNT_UID=
STARLING_CATEGORY_UID=
STARLING_SETTLE_UP_LINK=

# =============================================================================
# Demo configuration
# =============================================================================
NEXT_PUBLIC_DEMO_BASE_URL=http://localhost:3000
